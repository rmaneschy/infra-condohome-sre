# =====================================================
# CondoHome Platform - Staging Environment
# Copie para .env.staging e substitua os placeholders
# =====================================================

# --- PostgreSQL ---
POSTGRES_USER=condohome_staging
POSTGRES_PASSWORD=CHANGE_ME_STAGING
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Service Ports ---
# Kong Gateway é o ponto de entrada centralizado
REGISTER_PORT=8081
BILLING_PORT=8082
DOCUMENTS_PORT=8083
AI_ASSISTANT_PORT=8085
NOTIFICATION_PORT=8086
BOOKING_PORT=8087
FINANCE_PORT=8088
N8N_PORT=5678

# --- Frontend Ports ---
PORTAL_WEB_PORT=3000
PORTARIA_PORT=3001

# --- Frontend Build Args ---
VITE_API_URL=https://staging-api.condohome.com.br
VITE_WS_URL=wss://staging-api.condohome.com.br

# --- Docker Image Tag ---
TAG=staging

# --- Billing ---
ASAAS_API_KEY=CHANGE_ME
ASAAS_ENVIRONMENT=sandbox

# --- AI Assistant ---
OPENAI_API_KEY=CHANGE_ME

# --- Notification ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME

# --- N8N ---
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME

# --- CORS (gerenciado pelo Kong) ---
# CORS_ALLOWED_ORIGINS é configurado no Kong via configs/kong/kong.yml
