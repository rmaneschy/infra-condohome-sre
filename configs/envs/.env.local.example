# =====================================================
# CondoHome Platform - Local Environment
# Copie para .env.local e preencha os valores sensiveis
# =====================================================

# --- Environment ---
# Ambiente de execução: desenvolvimento, staging, production
ENV=desenvolvimento

# --- PostgreSQL ---
POSTGRES_USER=condohome
POSTGRES_PASSWORD=condohome123
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Service Ports ---
REGISTER_PORT=8081
BILLING_PORT=8082
DOCUMENTS_PORT=8083
AI_ASSISTANT_PORT=8085
NOTIFICATION_PORT=8086
BOOKING_PORT=8087
FINANCE_PORT=8088
N8N_PORT=5678

# --- Frontend Ports ---
PORTAL_WEB_PORT=3000
PORTARIA_PORT=3001

# --- Frontend Build Args ---
# Kong Gateway é o novo ponto de entrada centralizado
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# --- Tools ---
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@condohome.com.br
PGADMIN_PASSWORD=admin123
REDIS_COMMANDER_PORT=8090

# --- Docker Image Tag ---
TAG=latest

# --- Billing (Asaas Sandbox) ---
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox

# --- AI Assistant ---
OPENAI_API_KEY=

# --- Notification (Email) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Notification (WhatsApp) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# --- N8N ---
N8N_USER=admin
N8N_PASSWORD=admin123

# --- Kong API Gateway ---
KONG_VERSION=3.9
KONG_PROXY_PORT=8000
KONG_PROXY_SSL_PORT=8443
KONG_ADMIN_PORT=8001
KONG_ADMIN_SSL_PORT=8444
KONG_ADMIN_GUI_PORT=8002
KONG_PG_PORT=5433
KONG_PG_USER=kong
KONG_PG_PASSWORD=kong123
KONG_PG_DATABASE=kong
KONG_LOG_LEVEL=info

# --- Kong API Keys (producao) ---
KONG_PORTAL_API_KEY=
KONG_PORTARIA_API_KEY=
KONG_N8N_API_KEY=
KONG_MOBILE_API_KEY=

# --- CORS (gerenciado pelo Kong) ---
# CORS_ALLOWED_ORIGINS é configurado no Kong via configs/kong/kong.yml
