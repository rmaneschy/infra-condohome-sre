# =====================================================
# CondoHome Platform - Local Environment
# Copie para .env.local e preencha os valores sensiveis
# =====================================================

# --- PostgreSQL ---
POSTGRES_USER=condohome
POSTGRES_PASSWORD=condohome123
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Service Ports ---
GATEWAY_PORT=8080
REGISTER_PORT=8081
BILLING_PORT=8082
DOCUMENTS_PORT=8083
AI_ASSISTANT_PORT=8085
NOTIFICATION_PORT=8086
BOOKING_PORT=8087
FINANCE_PORT=8088
N8N_PORT=5678

# --- Frontend Ports ---
PORTAL_WEB_PORT=3000
PORTARIA_PORT=3001

# --- Frontend Build Args ---
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080

# --- Tools ---
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@condohome.com.br
PGADMIN_PASSWORD=admin123
REDIS_COMMANDER_PORT=8090

# --- Docker Image Tag ---
TAG=latest

# --- Billing (Asaas Sandbox) ---
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox

# --- AI Assistant ---
OPENAI_API_KEY=

# --- Notification (Email) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Notification (WhatsApp) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# --- N8N ---
N8N_USER=admin
N8N_PASSWORD=admin123

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
