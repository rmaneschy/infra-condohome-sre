# =====================================================
# CondoHome Platform - Production Environment
# ATENÇÃO: Nunca commitar este arquivo com credenciais reais!
# Use secrets management (GitHub Secrets, Vault, etc.)
# =====================================================

# --- PostgreSQL ---
POSTGRES_USER=condohome_prod
POSTGRES_PASSWORD=CHANGE_ME_PRODUCTION
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Service Ports ---
GATEWAY_PORT=8080
REGISTER_PORT=8081
BILLING_PORT=8082
DOCUMENTS_PORT=8083
AI_ASSISTANT_PORT=8085
NOTIFICATION_PORT=8086
BOOKING_PORT=8087
FINANCE_PORT=8088
N8N_PORT=5678

# --- Docker Image Tag ---
TAG=latest

# --- Billing ---
ASAAS_API_KEY=CHANGE_ME
ASAAS_ENVIRONMENT=production

# --- AI Assistant ---
OPENAI_API_KEY=CHANGE_ME

# --- Notification ---
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME

# --- N8N ---
N8N_USER=CHANGE_ME
N8N_PASSWORD=CHANGE_ME

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://condohome.com.br,https://app.condohome.com.br
